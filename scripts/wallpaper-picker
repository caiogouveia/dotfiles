#!/usr/bin/env zsh

setopt NULL_GLOB

LOG="/tmp/wallpaper-picker.log"
exec 2>>$LOG
echo "=== $(date) ===" >>$LOG

WALLPAPER_DIR="$HOME/Imagens/Wallpapers"
CACHE_DIR="$HOME/.cache/wallpaper-picker"
MAP_FILE="/tmp/wallpaper-picker-map.txt"
THUMBNAIL_WIDTH="128"
THUMBNAIL_HEIGHT="128"

mkdir -p "$CACHE_DIR"

MAGICK_CMD=$(command -v magick 2>/dev/null || command -v convert 2>/dev/null)
echo "magick: $MAGICK_CMD" >>$LOG
echo "HYPRLAND_INSTANCE_SIGNATURE: $HYPRLAND_INSTANCE_SIGNATURE" >>$LOG

generate_thumbnail() {
    local input="$1"
    local output="$2"

    "$MAGICK_CMD" "$input" -thumbnail "${THUMBNAIL_WIDTH}x${THUMBNAIL_HEIGHT}^" \
        -gravity center -extent "${THUMBNAIL_WIDTH}x${THUMBNAIL_HEIGHT}" \
        "$output"
}

generate_menu() {
    local count=0
    for img in $WALLPAPER_DIR/*.jpg $WALLPAPER_DIR/*.jpeg $WALLPAPER_DIR/*.png; do
        [[ -f "$img" ]] || continue
        count=$((count+1))
        filename=$(basename "$img")
        name_without_ext="${filename%.*}"
        thumbnail="$CACHE_DIR/${name_without_ext}.png"

        if [[ ! -f "$thumbnail" ]] || [[ "$img" -nt "$thumbnail" ]]; then
            echo "Gerando thumbnail: $thumbnail" >>$LOG
            generate_thumbnail "$img" "$thumbnail"
        fi

        printf "%s\0icon\x1f%s\n" "$name_without_ext" "$thumbnail"
    done
    echo "Total imagens: $count" >>$LOG
}

> "$MAP_FILE"
for img in $WALLPAPER_DIR/*.jpg $WALLPAPER_DIR/*.jpeg $WALLPAPER_DIR/*.png; do
    [[ -f "$img" ]] || continue
    name=$(basename "$img" | sed 's/\.[^.]*$//')
    echo "$name|$img" >> "$MAP_FILE"
done

echo "Abrindo fuzzel..." >>$LOG
selected=$(generate_menu | fuzzel --dmenu \
    --cache=/dev/null \
    --prompt "Wallpaper: " \
    --font "JetBrainsMono Nerd Font:size=12" \
    --lines 10 \
    --width 30)

echo "selected: '$selected'" >>$LOG

if [ -n "$selected" ]; then
    wallpaper_path=$(grep "^$selected|" "$MAP_FILE" | cut -d'|' -f2)
    echo "wallpaper_path: '$wallpaper_path'" >>$LOG

    if [ -n "$wallpaper_path" ] && [ -f "$wallpaper_path" ]; then
        if [ -n "$HYPRLAND_INSTANCE_SIGNATURE" ] || ls $XDG_RUNTIME_DIR/hypr/*/.hyprpaper.sock &>/dev/null; then
            # Detecta a instância ativa automaticamente
            ACTIVE_SIG=$(ls -t $XDG_RUNTIME_DIR/hypr/ 2>/dev/null | head -1)
            echo "Chamando hyprctl (instancia: $ACTIVE_SIG)..." >>$LOG
            HYPRLAND_INSTANCE_SIGNATURE=$ACTIVE_SIG hyprctl hyprpaper wallpaper ",$wallpaper_path" >>$LOG 2>&1
            echo "hyprctl exit: $?" >>$LOG
        elif [ "$XDG_CURRENT_DESKTOP" = "sway" ] || [ -n "$SWAYSOCK" ]; then
            swaymsg "output * bg $wallpaper_path fill"
        fi
        notify-send "Wallpaper" "Changed to $(basename "$wallpaper_path")" -i "$wallpaper_path" 2>/dev/null
    else
        echo "ERRO: wallpaper_path vazio ou arquivo nao existe" >>$LOG
        echo "Conteudo do map:" >>$LOG
        cat "$MAP_FILE" >>$LOG
    fi
else
    echo "selected vazio - usuario cancelou ou fuzzel falhou" >>$LOG
fi
