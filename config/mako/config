# Estilo geral (igual ao waybar/fuzzel: fundo preto translúcido, borda laranja)
font=JetBrainsMono Nerd Font 11
background-color=#000000A6
text-color=#FFFFFFFF
border-color=#FFA000D9
border-size=2
border-radius=15
padding=15,20
margin=10
progress-color=over #FFA000FF

# Ícones
icons=1
max-icon-size=48
icon-location=left
icon-border-radius=8

# Tempo de exibição (10 segundos)
default-timeout=10000

# Posição (canto superior direito)
layer=overlay
anchor=top-right

[urgency=low]
border-color=#FFFFFF4D

[urgency=critical]
border-color=#FF0000E6
default-timeout=0
